{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  },
  "boundaries": {
    "tags": {
      "app": { "dependencies": { "allow": ["shared", "visual", "ui"] } },
      "ui": { "dependencies": { "allow": ["shared", "visual"] } },
      "visual": { "dependencies": { "allow": ["shared"] } },
      "shared": { "dependencies": { "deny": ["app", "visual", "ui"] } }
    }
  }
}
